elpac25 %>% filter(type_id == 3, grade == 13, student_group_id == 1, county_code == "30") %>%
tabyl(total_students_enrolled) # this matches total students enrolled on website
elpac25 <- elpac25 %>%
rename(year = test_year, demo_group = student_group_id,
org_level = type_id, # type_id is school, district, county, etc.
test = test_id, test_enrollment = total_students_enrolled,
tested = total_students_tested, tested_scores = total_students_tested_with_scores) %>%
rename_with(~ str_replace(.x, "^oral_lang_", "oral_"), .cols = starts_with("oral_lang_")) %>%
rename_with(~ str_replace(.x, "^writ_lang_", "writ_"), .cols = starts_with("writ_lang_")) %>%
rename_with(~ str_replace(.x, "perf_lvl", "lvl"), .cols = contains("perf_lvl")) %>%
rename_with(~ str_replace(.x, "mean_scl_scr", "mean_score"), .cols = contains("mean_scl_scr")) %>%
rename_with(~ str_replace_all(.x, "([0-9])pcnt", "\\1_perc"), .cols = contains("pcnt")) %>%
rename_with(~ str_replace_all(.x, "([0-9])count", "\\1_count"), .cols = contains("count")) %>%
rename_with(~ str_replace(.x, "^listening_domain_", "d1_"), .cols = starts_with("listening_domain_")) %>%
rename_with(~ str_replace(.x, "^speaking_domain_",  "d2_"), .cols = starts_with("speaking_domain_")) %>%
rename_with(~ str_replace(.x, "^reading_domain_",   "d3_"), .cols = starts_with("reading_domain_")) %>%
rename_with(~ str_replace(.x, "^writing_domain_",   "d4_"), .cols = starts_with("writing_domain_")) %>%
rename_with(~ str_replace(.x, "_pcnt$", "_perc"), .cols = matches("_pcnt$"))
names(elpac25) # check renaming worked
names(elpac25)
