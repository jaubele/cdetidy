key_cols = c("cds", "year"))
assessment_entities_distinct <- validate_combined_data(assessment_entities_joined,
key_cols = c("cds", "year"),
full_run = T)
rm(assessment_districts_joined, assessment_entities_joined, assessment_schools_joined)
rm(assessment_districts_joined, assessment_entities_joined, assessment_schools_joined,
assessment_districts_canon, assessment_schools_canon, assessment_schools_canon)
rm(assessment_districts_joined, assessment_entities_joined, assessment_schools_joined,
assessment_districts_canon, assessment_schools_canon, assessment_schools_canon,
zip_dupes, zip_schools_flagged)
