arrange(dup_zip, school_code, year)
zip_schools_flagged %>%
arrange(desc(dup_zip, school_code, year))
zip_schools_flagged %>%
arrange(desc(dup_zip))
zip_schools_flagged %>%
arrange(desc(dup_zip)) %>%
arrange(school_code)
zip_schools_flagged %>%
filter(dup_zip == 1) %>%
arrange(school_code)
names(zip_schools_flagged)
assessment_schools_distinct <- zip_schools_flagged %>%
select(-school_name_old) %>%
validate_combined_data(key_cols = c("school_code", "year"))
assessment_schools_distinct <- zip_schools_flagged %>%
select(-school_name_old) %>%
validate_combined_data(key_cols = c("school_code", "year"),
full_run = T)
